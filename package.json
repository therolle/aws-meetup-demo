{
  "name": "aws-meetup-demo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "audit": "npm audit --omit=dev",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --no-warn-ignored",
      "prettier --check"
    ],
    "*.{json,md,css}": [
      "prettier --check"
    ]
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6",
    "@tanstack/react-router": "^1.166.7",
    "aws-amplify": "^6",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1",
    "@aws-amplify/backend-cli": "^1",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4",
    "@tanstack/router-devtools": "^1.166.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "tailwindcss": "^4",
    "typescript": "~5.7",
    "typescript-eslint": "^8.57.0",
    "vite": "^6",
    "vitest": "^4.0.18"
  }
}
